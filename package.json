{
  "name": "norevify",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "dev": "next dev --turbo",
    "build": "next build --webpack",
    "start": "next start",
    "test:unit": "npm run test:unit:backend && npm run test:unit:frontend",
    "test:unit:backend": "node --test \"test/unit/**/*.test.js\"",
    "test:unit:frontend": "vitest run --config vitest.config.ts",
    "test:unit:coverage": "npm run test:unit:backend:coverage && npm run test:unit:frontend:coverage",
    "test:unit:backend:coverage": "c8 --reporter=text --reporter=html node --test \"test/unit/**/*.test.js\"",
    "test:unit:frontend:coverage": "vitest run --config vitest.config.ts --coverage",
    "test:integration": "node --test \"test/integration/**/*.test.js\"",
    "test:integration:coverage": "c8 --reporter=text --reporter=html node --test \"test/integration/**/*.test.js\"",
    "test:backend": "node --test \"test/unit/**/*.test.js\" \"test/integration/**/*.test.js\"",
    "test:api": "set NODE_OPTIONS=--use-system-ca&&mocha",
    "test:api:report": "set NODE_OPTIONS=--use-system-ca&&mocha --reporter mochawesome --reporter-options reportDir=reports,reportFilename=report,overwrite=true",
    "test:e2e": "set NODE_OPTIONS=--use-system-ca&&playwright test --config playwright.config.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rafaabc/norevify.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/rafaabc/norevify/issues"
  },
  "homepage": "https://github.com/rafaabc/norevify#readme",
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "@sentry/nextjs": "^10.53.1",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "google-auth-library": "^10.6.2",
    "i18next": "^26.2.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.16.0",
    "mongoose": "^9.6.1",
    "next": "16.2.6",
    "pino": "^10.3.1",
    "posthog-js": "^1.374.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "resend": "^6.12.3",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.47.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^2.1.9",
    "c8": "^11.0.0",
    "chai": "^4.5.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.7",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^25.0.1",
    "mocha": "^10.8.2",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^4.3.0",
    "mochawesome-report-generator": "^6.2.0",
    "mongodb-memory-server": "^11.1.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "supertest": "^6.3.4",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "serialize-javascript": "^7.0.5"
  }
}
