{
  "name": "drive-ledger",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "dev": "nodemon src/server.js",
    "next:dev": "next dev",
    "next:build": "next build",
    "next:start": "next start",
    "start": "node src/server.js",
    "test:unit": "node --test \"test/unit/**/*.test.js\"",
    "test:unit:coverage": "c8 --reporter=text --reporter=html node --test \"test/unit/**/*.test.js\"",
    "test:integration": "node --test \"test/integration/**/*.test.js\"",
    "test:integration:coverage": "c8 --reporter=text --reporter=html node --test \"test/integration/**/*.test.js\"",
    "test:backend": "node --test \"test/unit/**/*.test.js\" \"test/integration/**/*.test.js\"",
    "test:api": "mocha",
    "test:api:report": "mocha --reporter mochawesome --reporter-options reportDir=reports,reportFilename=report,overwrite=true",
    "test:front": "jest --config jest.config.cjs",
    "test:front:watch": "jest --config jest.config.cjs --watch",
    "test:front:coverage": "c8 --reporter=text --reporter=html jest --config jest.config.cjs",
    "test:e2e": "playwright test --config playwright.config.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rafaabc/drive-ledger.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/rafaabc/drive-ledger/issues"
  },
  "homepage": "https://github.com/rafaabc/drive-ledger#readme",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "google-auth-library": "^10.6.2",
    "i18next": "^26.2.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.16.0",
    "mongoose": "^9.6.1",
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.8",
    "recharts": "^3.8.1",
    "resend": "^6.12.3",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@babel/preset-env": "^7.25.0",
    "@babel/preset-react": "^7.24.0",
    "@playwright/test": "^1.47.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "babel-jest": "^30.3.0",
    "c8": "^11.0.0",
    "chai": "^4.5.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "mocha": "^10.8.2",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^4.3.0",
    "mochawesome-report-generator": "^6.2.0",
    "mongodb-memory-server": "^11.1.0",
    "nodemon": "^3.1.14",
    "supertest": "^6.3.4"
  }
}
