  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "test:unit": "node --test \"test/unit/**/*.test.js\"",
    "test:unit:coverage": "c8 --reporter=text --reporter=html node --test \"test/unit/**/*.test.js\"",
    "test:integration": "node --test \"test/integration/**/*.test.js\"",
    "test:integration:coverage": "c8 --reporter=text --reporter=html node --test \"test/integration/**/*.test.js\"",
    "test:backend": "node --test \"test/unit/**/*.test.js\" \"test/integration/**/*.test.js\"",
    "test:api": "mocha",
    "test:api:report": "mocha --reporter mochawesome --reporter-options reportDir=reports,reportFilename=report,overwrite=true"
  },
